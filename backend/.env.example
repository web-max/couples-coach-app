# Backend config. Copy to .env and fill in. See src/config.ts (loadConfig).

# --- Required ---
# OpenRouter API key for model calls.
OPENROUTER_API_KEY=

# JWT verification: set ONE of the two below.
#   SUPABASE_JWT_SECRET -> HS256 (legacy Supabase JWT secret)
#   SUPABASE_URL        -> asymmetric via {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=
SUPABASE_URL=

# --- Optional (defaults shown) ---
PORT=3000
MODEL_ID=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=300000
