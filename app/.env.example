# Expo app config. Copy to .env and fill in. See lib/supabase.ts.
# EXPO_PUBLIC_* vars are bundled into the client — public values only, no secrets.

# Supabase project URL and anon (public) key.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend relay base URL (the backend service).
EXPO_PUBLIC_RELAY_URL=
